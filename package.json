{
  "name": "color-changer",
  "version": "5.0.0",
  "description": "Change a page's text, background, and link colors to your liking.",
  "types": "module",
  "scripts": {
    "dev": "vite",
    "build:ff": "npm run build:extension && npm run copy-ff-manifest",
    "build:chrome": "npm run build:extension && npm run copy-chrome-manifest",
    "build:extension": "tsc && vite build --config vite.popup.ts && vite build --config vite.content.ts",
    "preview": "vite preview",
    "copy-ff-manifest": "node ./scripts/copy-manifest.js src/manifest.ff.json",
    "copy-chrome-manifest": "node ./scripts/copy-manifest.js src/manifest.chrome.json",
    "zip:ff": "npm run build:ff && powershell -NoProfile -File ./scripts/zip.ps1",
    "zip:chrome": "npm run build:chrome && powershell -NoProfile -File ./scripts/zip.ps1",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rokit/web-extension-color-changer"
  },
  "author": "Luke Simpson",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/rokit/web-extension-color-changer/issues"
  },
  "homepage": "https://github.com/rokit/web-extension-color-changer#readme",
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^26.1.1",
    "color-convert": "^3.1.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
